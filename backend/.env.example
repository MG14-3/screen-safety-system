# SafeScreen Backend — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/safescreen?retryWrites=true&w=majority
PORT=3000
JWT_SECRET=change_this_to_a_random_secret
